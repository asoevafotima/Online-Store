# Скопируйте в .env и заполните своими значениями: cp .env.example .env

# --- Безопасность ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- База данных ---
DATABASE_URL=sqlite:///./database.db

# --- CORS (origin'ы фронтенда через запятую; * = любые, удобно для разработки) ---
# Для продакшена укажите конкретные домены: https://example.com,https://www.example.com
CORS_ORIGINS=*

# --- AI-ассистент (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
